# Clockify — régénère la clé si elle a été exposée (profil Clockify → API)
CLOCKIFY_API_KEY=

# Nom du workspace (recherche insensible à la casse)
CLOCKIFY_WORKSPACE_NAME=Wenov

# Optionnel si ton workspace est sur une autre région API
# CLOCKIFY_API_BASE_URL=https://api.clockify.me/api/v1
# CLOCKIFY_REPORTS_BASE_URL=https://reports.api.clockify.me/v1
# Limite de pages pour le rapport détaillé (évite une boucle infinie si l’API pagine mal)
# CLOCKIFY_DETAILED_MAX_PAGES=1000

TIMEZONE=America/Toronto

# yesterday = journée complète précédente | today = depuis minuit jusqu'à maintenant
REPORT_DAY=yesterday

# Seuils alertes (heures)
PROJECT_HOURS_ALERT_THRESHOLD=3
ALERT_LOW_HOURS=4
ALERT_HIGH_HOURS=10
ALERT_MAX_ENTRIES_PER_DAY=15
WORK_HOUR_START=8
WORK_HOUR_END=20
FULL_DAY_HOURS_MIN=7
FULL_DAY_HOURS_MAX=10
LONG_TASK_REPEAT_HOURS=2
PROJECT_EXPECTED_HOURS=8

# Projets prioritaires (optionnel, IDs Clockify ou noms séparés par des virgules)
# PRIORITY_PROJECT_IDS=
# PRIORITY_PROJECT_NAMES=Client VIP,Production

# fr | en
LOCALE=fr

# Resend — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Rapport Clockify <noreply@wenov.ca>
# Plusieurs destinataires : virgules ou points-virgules
EMAIL_TO=ads@wenov.ca,wenovsolutions@gmail.com

# Optionnel : CRON_SECRET pour /daily-report et /preview-email
# CRON_SECRET=
